# ad-scout environment variables
# Copy this file to .env and fill in your keys.
# NEVER commit .env to version control.

# Meta (Facebook) User Access Token with ads_read permission.
# Get one at: https://developers.facebook.com/tools/explorer/
# Required for live mode (ad-scout <brand>).
# Not needed for --demo or --offline mode.
META_ACCESS_TOKEN=

# Anthropic API key.
# Get one at: https://console.anthropic.com/keys
# Required for live mode and --demo mode.
# Not needed for --offline mode.
ANTHROPIC_API_KEY=
